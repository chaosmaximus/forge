.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Rust ─────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock.bak

# ── Python (for optional tooling) ────────────────────────────────────
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Forge runtime (not in repo) ─────────────────────────────────────
.forge/
.claude/
.serena/

