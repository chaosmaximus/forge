#!/usr/bin/env bash
# Forge-graph MCP server launcher
# Finds Python (venv or system) and starts the MCP server
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"

# Try venv first, then system python3
if [ -f "$SCRIPT_DIR/.venv/bin/python3" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python3"
elif command -v python3 &>/dev/null; then
    PYTHON="python3"
else
    echo "Python 3 not found" >&2
    exit 1
fi

PYTHONPATH="$SCRIPT_DIR/forge-graph/src" exec "$PYTHON" -m forge_graph.server "$@"
